<link rel="stylesheet" href="/shared.css">
<style>
/* ═══ CONTACT LAYOUT ═══ */
.contact-layout {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: clamp(40px, 6vw, 80px);
  max-width: 1300px;
  margin: 0 auto;
}
.contact-info-item {
  padding: 24px 0;
  border-bottom: 1px solid var(--border-light);
}
.contact-info-item:last-child { border-bottom: none; }
.ci-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.ci-value {
  font-family: var(--font-heading);
  font-size: clamp(1.1rem, 1.5vw, 1.4rem);
  font-weight: 400;
  color: var(--text-primary);
}
.ci-value a {
  color: var(--text-primary);
  text-decoration: none;
  transition: color 0.2s;
}
.ci-value a:hover { color: var(--accent); }

.social-links {
  display: flex;
  gap: 20px;
  margin-top: 32px;
}
.social-links a {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 0.2s;
}
.social-links a:hover { color: var(--accent); }

/* ═══ CONTACT MAP PLACEHOLDER (in left column) ═══ */
.contact-map-small {
  margin-top: 32px;
  width: 100%;
  height: 200px;
  background: #e8ecf2;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 400;
  color: var(--text-secondary);
}

/* ═══ INLINE FORM CARD ═══ */
.inline-form {
  background: #fff;
  border-radius: 16px;
  padding: clamp(32px, 4vw, 48px);
  box-shadow: 0 4px 32px rgba(0,0,0,0.05);
}

/* Inline form progress */
.inline-progress {
  display: flex;
  gap: 8px;
  margin-bottom: 32px;
}
.inline-progress-bar {
  flex: 1;
  height: 3px;
  background: var(--border-light);
  border-radius: 2px;
  transition: background 0.4s ease;
}
.inline-progress-bar.active {
  background: var(--accent);
}

/* Inline form steps */
.inline-step {
  display: none;
}
.inline-step.active {
  display: block;
}
.inline-step-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.inline-step-title {
  font-family: var(--font-heading);
  font-size: clamp(1.3rem, 2vw, 1.8rem);
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 24px;
}

/* Inline option grid */
.inline-option-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 32px;
}
.inline-option-btn {
  padding: 16px 20px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: transparent;
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: center;
}
.inline-option-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
}
.inline-option-btn.selected {
  border-color: var(--accent);
  background: rgba(37,99,235,0.06);
  color: var(--accent);
}

/* Inline form groups */
.inline-form .form-group {
  margin-bottom: 20px;
}
.inline-form .form-group label {
  display: block;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.inline-form .form-group input,
.inline-form .form-group textarea {
  width: 100%;
  padding: 14px 16px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--text-primary);
  background: transparent;
  outline: none;
  transition: border-color 0.3s ease;
  box-sizing: border-box;
}
.inline-form .form-group input:focus,
.inline-form .form-group textarea:focus {
  border-color: var(--accent);
}
.inline-form .form-group textarea {
  resize: vertical;
  min-height: 100px;
}

/* Inline form navigation */
.inline-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24px;
}
.inline-back {
  padding: 12px 24px;
  border: none;
  background: none;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--text-secondary);
  cursor: pointer;
  transition: color 0.2s;
}
.inline-back:hover { color: var(--text-primary); }
.inline-next {
  padding: 14px 32px;
  border: none;
  border-radius: 8px;
  background: var(--accent);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: background 0.3s ease, transform 0.2s ease;
}
.inline-next:hover {
  background: #1d4ed8;
  transform: translateY(-1px);
}

/* Inline form success */
.inline-success {
  display: none;
  text-align: center;
  padding: 48px 24px;
}
.inline-success.active {
  display: block;
}
.inline-success-check {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
}
.inline-success-title {
  font-family: var(--font-heading);
  font-size: 1.8rem;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 12px;
}
.inline-success-desc {
  font-size: 0.9rem;
  line-height: 1.7;
  color: var(--text-secondary);
  max-width: 400px;
  margin: 0 auto;
}

/* ═══ MAP SECTION ═══ */
.map-placeholder {
  height: 350px;
  background: #1a1a2e;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.map-placeholder .blueprint-grid { opacity: 0.3; }
.map-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 12px;
  position: relative;
  z-index: 2;
}
.map-address {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 300;
  color: rgba(255,255,255,0.8);
  position: relative;
  z-index: 2;
}

/* ═══ CONTACT SECTION BG ═══ */
.contact-section {
  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  position: relative;
  overflow: hidden;
}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 900px) {
  .contact-layout { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .inline-option-grid { grid-template-columns: 1fr; }
}
</style>
