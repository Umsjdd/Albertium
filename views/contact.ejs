<!-- ═══ INLINE FORM JS ═══ -->
<script>
(function() {
  const form = document.getElementById('inlineForm');
  if (!form) return;

  const steps = form.querySelectorAll('.inline-step');
  const progressBars = form.querySelectorAll('.inline-progress-bar');
  const successEl = document.getElementById('inlineSuccess');
  const progressContainer = document.getElementById('inlineProgress');

  let currentStep = 1;
  const formData = {};

  // Option button selection
  form.addEventListener('click', function(e) {
    const btn = e.target.closest('.inline-option-btn');
    if (!btn) return;

    const step = btn.closest('.inline-step');
    step.querySelectorAll('.inline-option-btn').forEach(function(b) {
      b.classList.remove('selected');
    });
    btn.classList.add('selected');
  });

  // Navigate to a step
  function goToStep(stepNum) {
    currentStep = stepNum;
    steps.forEach(function(s) {
      s.classList.remove('active');
      if (parseInt(s.getAttribute('data-inline-step')) === stepNum) {
        s.classList.add('active');
      }
    });
    // Update progress
    progressBars.forEach(function(bar, i) {
      bar.classList.toggle('active', i < stepNum);
    });
  }

  // Back buttons
  form.querySelectorAll('.inline-back').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var goto = parseInt(btn.getAttribute('data-inline-goto'));
      goToStep(goto);
    });
  });

  // Step 1 Next
  document.getElementById('inlineStep1Next').addEventListener('click', function() {
    var selected = form.querySelector('.inline-step[data-inline-step="1"] .inline-option-btn.selected');
    if (!selected) return;
    formData.projectType = selected.getAttribute('data-inline-value');
    goToStep(2);
  });

  // Step 2 Next
  document.getElementById('inlineStep2Next').addEventListener('click', function() {
    var selected = form.querySelector('.inline-step[data-inline-step="2"] .inline-option-btn.selected');
    if (!selected) return;
    formData.budget = selected.getAttribute('data-inline-value');
    goToStep(3);
  });

  // Step 3 Next
  document.getElementById('inlineStep3Next').addEventListener('click', function() {
    var selected = form.querySelector('.inline-step[data-inline-step="3"] .inline-option-btn.selected');
    if (!selected) return;
    formData.timeline = selected.getAttribute('data-inline-value');
    goToStep(4);
  });

  // Submit
  document.getElementById('inlineFormSubmit').addEventListener('click', function() {
    var name = document.getElementById('inlineFormName').value.trim();
    var email = document.getElementById('inlineFormEmail').value.trim();
    if (!name || !email) return;

    formData.name = name;
    formData.email = email;
    formData.phone = document.getElementById('inlineFormPhone').value.trim();
    formData.description = document.getElementById('inlineFormDesc').value.trim();

    // Hide steps and progress, show success
    steps.forEach(function(s) { s.classList.remove('active'); });
    progressContainer.style.display = 'none';
    successEl.classList.add('active');

    console.log('Inline form submitted:', formData);
  });
})();
</script>

</body>
</html>
