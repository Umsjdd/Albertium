<%- include('../_shell_open', { title: 'Services', heading: heading, section: section, user: user, flash: flash, headerAction: headerAction }) %>

<div class="card" style="padding: 0;">
  <table class="table">
    <thead>
      <tr>
        <th style="width: 60px;">#</th>
        <th>Title</th>
        <th>Description</th>
        <th style="width: 100px;">Features</th>
        <th class="row-actions" style="width: 180px;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% services.forEach(function(service) { %>
        <tr>
          <td><%= service.number %></td>
          <td>
            <strong><%= service.title %></strong>
            <div class="muted" style="font-size: 12px;"><%= service.slug %></div>
          </td>
          <td class="muted" style="max-width: 380px;"><%= service.description %></td>
          <td><%= featureCount[service.id] || 0 %></td>
          <td class="row-actions">
            <a href="/admin/services/<%= service.id %>/edit" class="btn btn-sm">Edit</a>
            <form method="POST" action="/admin/services/<%= service.id %>/delete" style="display: inline;" onsubmit="return confirm('Delete &ldquo;<%= service.title %>&rdquo;?');">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../_shell_close') %>
