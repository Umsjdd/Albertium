<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Not found — Albertium</title>
<link rel="stylesheet" href="/shared.css">
<style>
  body { min-height: 100vh; display: grid; place-items: center; text-align: center; padding: 40px; }
