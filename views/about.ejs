<!-- ═══ CONTACT MODAL ═══ -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <button class="modal-close" id="modalClose">&times;</button>
    <div id="modalForm">
      <div class="modal-progress" id="modalProgress">
        <div class="modal-progress-bar active"></div>
        <div class="modal-progress-bar"></div>
        <div class="modal-progress-bar"></div>
        <div class="modal-progress-bar"></div>
      </div>

      <!-- Step 1 -->
      <div class="modal-step active" data-step="1">
        <div class="modal-step-label">Step 1 of 4</div>
        <div class="modal-step-title">What type of project?</div>
        <div class="option-grid">
          <button class="option-btn" data-value="Residential">Residential</button>
          <button class="option-btn" data-value="Commercial">Commercial</button>
          <button class="option-btn" data-value="Cultural">Cultural</button>
          <button class="option-btn" data-value="Interior">Interior</button>
          <button class="option-btn" data-value="Mixed-Use">Mixed-Use</button>
          <button class="option-btn" data-value="Other">Other</button>
        </div>
        <div class="modal-nav">
          <div></div>
          <button class="modal-next" id="step1Next">Continue</button>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="modal-step" data-step="2">
        <div class="modal-step-label">Step 2 of 4</div>
        <div class="modal-step-title">Estimated budget range?</div>
        <div class="option-grid">
          <button class="option-btn" data-value="Under £250K">Under &pound;250K</button>
          <button class="option-btn" data-value="£250K–£500K">&pound;250K &ndash; &pound;500K</button>
          <button class="option-btn" data-value="£500K–£1M">&pound;500K &ndash; &pound;1M</button>
          <button class="option-btn" data-value="£1M–£5M">&pound;1M &ndash; &pound;5M</button>
          <button class="option-btn" data-value="£5M+">&pound;5M+</button>
          <button class="option-btn" data-value="Not Sure Yet">Not Sure Yet</button>
        </div>
        <div class="modal-nav">
          <button class="modal-back" data-goto="1">Back</button>
          <button class="modal-next" id="step2Next">Continue</button>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="modal-step" data-step="3">
        <div class="modal-step-label">Step 3 of 4</div>
        <div class="modal-step-title">Project timeline?</div>
        <div class="option-grid">
          <button class="option-btn" data-value="Immediate">Immediate</button>
          <button class="option-btn" data-value="3–6 Months">3 &ndash; 6 Months</button>
          <button class="option-btn" data-value="6–12 Months">6 &ndash; 12 Months</button>
          <button class="option-btn" data-value="12+ Months">12+ Months</button>
          <button class="option-btn" data-value="Flexible">Flexible</button>
          <button class="option-btn" data-value="Urgent">Urgent</button>
        </div>
        <div class="modal-nav">
          <button class="modal-back" data-goto="2">Back</button>
          <button class="modal-next" id="step3Next">Continue</button>
        </div>
      </div>

      <!-- Step 4 -->
      <div class="modal-step" data-step="4">
        <div class="modal-step-label">Step 4 of 4</div>
        <div class="modal-step-title">Your details</div>
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" placeholder="John Doe" id="formName">
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" placeholder="john@example.com" id="formEmail">
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="tel" placeholder="+44 7XXX XXXXXX" id="formPhone">
        </div>
        <div class="form-group">
          <label>Brief Description</label>
          <textarea placeholder="Tell us about your project vision..." id="formDesc"></textarea>
        </div>
        <div class="modal-nav">
          <button class="modal-back" data-goto="3">Back</button>
          <button class="modal-next" id="formSubmit">Submit</button>
        </div>
      </div>
    </div>

    <!-- Success -->
    <div class="modal-success" id="modalSuccess">
      <div class="success-check">&#10003;</div>
      <div class="success-title">Thank You</div>
      <p class="success-desc">Your project enquiry has been received. Our team will be in touch within 24 hours to discuss your vision.</p>
    </div>
  </div>
</div>

