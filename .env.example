# Replit Postgres — provision a DB via the Replit sidebar and this is auto-injected
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Express session secret — generate with `openssl rand -hex 32`
SESSION_SECRET=change-me-to-a-long-random-string

# Resend API key for contact-form notification emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions get emailed to
CONTACT_NOTIFY_EMAIL=info@albertium.com
CONTACT_FROM_EMAIL=website@albertium.com

# Initial admin credentials — only read by `npm run db:seed`, safe to remove after first seed
ADMIN_EMAIL=admin@albertium.com
ADMIN_PASSWORD=change-me-after-first-login

# Port (Replit sets this for you)
PORT=5000
