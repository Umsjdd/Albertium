modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
entrypoint = "server/index.ts"

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "install"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true
