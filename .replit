modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
entrypoint = "server/index.ts"

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "install"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80
