modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 5000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "install"]
# Bypass `npm run start` and exec tsx directly. Replit's autoscale
# production runner sometimes mis-passes env vars through npm script
# wrappers, which surfaced as "no run command provided" on first deploy.
# Inline NODE_ENV here since the Replit deployment env is configured
# in the UI, not via .replit's [env] block.
run = ["sh", "-c", "NODE_ENV=production node_modules/.bin/tsx server/index.ts"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true
